{
  "name": "BestCheckout merchant admin prototype",
  "entry": "index.html",
  "staticRoot": ".",
  "routing": {
    "prototype": "hash",
    "production": "merchant-admin-and-marketing-routes"
  },
  "contracts": {
    "funnelDeploymentSchema": "bestcheckout.funnel-deployment.v1",
    "cartHandoffSchema": "bestcheckout.cart-handoff.v1",
    "trackingContract": "bestcheckout.tracking.v1",
    "prototypeHashAlgorithm": "prototype-fnv1a32",
    "productionHashAlgorithm": "canonical-json-v1+sha256",
    "editorCoreTarget": "@bestshopio/checkout-editor-core"
  },
  "localPreview": {
    "command": "python -m http.server 4175",
    "url": "http://127.0.0.1:4175/#/home"
  },
  "githubPages": {
    "branch": "main",
    "directory": "/",
    "buildRequired": false,
    "jekyll": false,
    "publicWhitelist": [
      ".nojekyll",
      "404.html",
      "index.html",
      "preview.config.json",
      "assets/**",
      "account/**",
      "activity/**",
      "analytics/**",
      "apps/**",
      "bestcheckout/**",
      "blog/**",
      "bundles/**",
      "collections/**",
      "customers/**",
      "discounts/**",
      "facebook/**",
      "google/**",
      "help/**",
      "home/**",
      "landing/**",
      "menu/**",
      "online-store/**",
      "orders/**",
      "page/**",
      "products/**",
      "reviews/**",
      "settings/**",
      "storefront/**",
      "subscriptions/**",
      "src/views/admin/bestcheckout/**"
    ],
    "targetOptions": [
      {
        "repo": "zjc66666-pm/BestCheckout",
        "path": "/",
        "status": "current-target"
      }
    ]
  },
  "smokeRoutes": [
    "landing/#/landing",
    "#/home",
    "#/flows",
    "#/pages",
    "#/orders",
    "#/activity",
    "#/settings/base",
    "#/settings/domains",
    "#/settings/payments",
    "help/#guide=connect-shopify"
  ],
  "interactionSmoke": [
    "English -> 简体中文 -> English",
    "Pages editor -> desktop/mobile preview",
    "Funnel node editor -> live pin/latest page/draft context",
    "Create typed Page -> replace Funnel node page",
    "Draft page publish -> Funnel republish",
    "Pause -> resume last deployment without publishing draft",
    "Pause -> publish current draft and resume"
  ]
}
