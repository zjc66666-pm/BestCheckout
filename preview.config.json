{
  "name": "BestCheckout website and standalone merchant admin",
  "entry": "index.html",
  "staticRoot": ".",
  "routing": {
    "website": "hash routes at repository root",
    "admin": "hash routes under /app/",
    "legacyLanding": "redirects /landing/ to repository root"
  },
  "contracts": {
    "funnelDeploymentSchema": "bestcheckout.funnel-deployment.v1",
    "cartHandoffSchema": "bestcheckout.cart-handoff.v1",
    "trackingContract": "bestcheckout.tracking.v1"
  },
  "localPreview": {
    "command": "python -m http.server 4195 --bind 127.0.0.1",
    "websiteUrl": "http://127.0.0.1:4195/#/landing",
    "adminUrl": "http://127.0.0.1:4195/app/#/home",
    "helpUrl": "http://127.0.0.1:4195/help/#guide=connect-shopify"
  },
  "githubPages": {
    "branch": "main",
    "directory": "/",
    "buildRequired": false,
    "jekyll": false,
    "publicWhitelist": [
      ".gitattributes",
      ".gitignore",
      ".nojekyll",
      "404.html",
      "README.md",
      "index.html",
      "preview.config.json",
      "app/**",
      "landing/**",
      "help/**",
      "assets/**",
      "home/js/data.js",
      "bestcheckout/**",
      "orders/**",
      "activity/**",
      "settings/**",
      "online-store/**",
      "bundles/js/data.js",
      "subscriptions/js/data.js",
      "src/views/admin/bestcheckout/**"
    ],
    "target": {
      "repo": "zjc66666-pm/BestCheckout",
      "path": "/",
      "status": "current-target-after-review"
    }
  },
  "smokeRoutes": [
    "#/landing",
    "#/sign-in",
    "#/sign-up?next=connect-shopify",
    "#/forgot-password",
    "#/connect-shopify",
    "help/#guide=connect-shopify",
    "app/#/home",
    "app/#/flows",
    "app/#/pages",
    "app/#/orders",
    "app/#/activity",
    "app/#/settings/base",
    "app/#/settings/domains",
    "app/#/settings/payments"
  ],
  "interactionSmoke": [
    "Website Start free -> sign up -> connect Shopify -> admin Overview",
    "Sign in -> admin Overview",
    "Forgot password code countdown and resend",
    "Purchase flow list -> canvas -> Checkout page editor",
    "Checkout domain automatic and manual verification states",
    "Order detail with bundle and subscription metadata",
    "English -> Simplified Chinese -> English"
  ]
}
